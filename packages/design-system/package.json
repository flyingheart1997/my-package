{
    "name": "@org-design-system/core",
    "version": "0.1.15",
    "description": "The professional design system for organization",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "style": "./dist/index.css",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js",
            "style": "./dist/index.css"
        },
        "./style.css": "./dist/index.css",
        "./styles.css": "./dist/index.css",
        "./styles": "./dist/index.css",
        "./components": {
            "types": "./dist/components.d.ts",
            "import": "./dist/components.mjs",
            "require": "./dist/components.js"
        },
        "./icons": {
            "types": "./dist/icons.d.ts",
            "import": "./dist/icons.mjs",
            "require": "./dist/icons.js"
        },
        "./tokens": {
            "types": "./dist/tokens.d.ts",
            "import": "./dist/tokens.mjs",
            "require": "./dist/tokens.js"
        }
    },
    "dependencies": {
        "@org-design-system/styles": "workspace:*",
        "@org-design-system/components": "workspace:*",
        "@org-design-system/icons": "workspace:*"
    },
    "peerDependencies": {
        "@org-design-system/styles": "*",
        "@org-design-system/components": "*",
        "@org-design-system/icons": "*"
    },
    "peerDependenciesMeta": {
        "@org-design-system/styles": {
            "optional": false
        },
        "@org-design-system/components": {
            "optional": false
        },
        "@org-design-system/icons": {
            "optional": false
        }
    },
    "scripts": {
        "build": "tsup && node bundle-css.mjs",
        "dev": "tsup --watch"
    },
    "devDependencies": {
        "tsup": "^8.5.1",
        "typescript": "^5.3.3"
    }
}