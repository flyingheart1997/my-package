{
    "name": "@org-design-system/components",
    "version": "0.1.16",
    "description": "UI components for the @org-design-system",
    "publishConfig": {
        "access": "public"
    },
    "sideEffects": [
        "**/*.css"
    ],
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "style": "./src/index.css",
    "source": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./index.css": "./dist/index.css",
        "./style.css": "./dist/index.css"
    },
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "build": "tsup && cp src/index.css dist/index.css && cp src/index.css dist/style.css",
        "dev": "concurrently \"tsup --watch\" \"npm run sync:watch\"",
        "sync": "tsx scripts/sync-components.ts",
        "sync:watch": "tsx scripts/sync-components.ts --watch",
        "lint": "tsc"
    },
    "dependencies": {
        "@org-design-system/icons": "workspace:*",
        "@org-design-system/styles": "workspace:*",
        "@radix-ui/react-alert-dialog": "^1.1.15",
        "@radix-ui/react-avatar": "^1.1.11",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-slot": "^1.1.2",
        "@radix-ui/react-toggle": "^1.1.10",
        "@radix-ui/react-tooltip": "^1.2.8",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "tailwind-merge": "^3.0.2",
        "tailwindcss": "^4.0.0"
    },
    "peerDependencies": {
        "react": ">=18",
        "react-dom": ">=18",
        "tailwindcss": ">=3"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.2.1",
        "@types/react": "19.0.10",
        "@types/react-dom": "19.0.4",
        "chokidar": "^5.0.0",
        "concurrently": "^9.2.1",
        "postcss": "^8.5.3",
        "tailwindcss": "^4.0.0",
        "tsup": "^8.4.0",
        "typescript": "^5.7.3"
    }
}